{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "neuralmarket:contract:pilot_portal_attestation:1.0",
  "title": "Pilot portal cost attestation",
  "description": "Short-lived manual operator record of the Databento portal's displayed cost estimate for the bound pilot scope. Complements (does not replace) the execution-layer portal_limit_attestation. Never stores portal cookies, account identifiers, credentials, or screenshots.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "template_only",
    "attested",
    "dataset_scope",
    "schema_scope",
    "symbol_scope",
    "window_start",
    "window_end",
    "portal_estimate_usd",
    "currency",
    "observed_at",
    "expires_at",
    "completed_checkpoint_sha256",
    "request_manifest_sha256",
    "operator_confirmation",
    "attestation_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "pilot-portal-attestation-v1"
    },
    "template_only": {
      "type": "boolean"
    },
    "attested": {
      "type": "boolean"
    },
    "dataset_scope": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "schema_scope": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "symbol_scope": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "window_start": {
      "type": "string",
      "format": "date-time"
    },
    "window_end": {
      "type": "string",
      "format": "date-time"
    },
    "portal_estimate_usd": {
      "type": ["string", "null"],
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "currency": {
      "const": "USD"
    },
    "observed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_checkpoint_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "request_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "operator_confirmation": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "attestation_hash": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
