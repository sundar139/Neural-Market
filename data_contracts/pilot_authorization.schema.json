{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "neuralmarket:contract:pilot_authorization:1.0",
  "type": "object",
  "required": [
    "authorization_version",
    "pilot_plan_hash",
    "source_manifest_hash",
    "split_manifest_hash",
    "acquisition_policy_hash",
    "maximum_spend_usd",
    "authorized_currency",
    "authorized_at",
    "expires_at",
    "authorized_by",
    "confirmation_phrase",
    "purchase_authorized",
    "authorization_hash"
  ],
  "properties": {
    "authorization_version": {
      "type": "string"
    },
    "pilot_plan_hash": {
      "type": "string"
    },
    "source_manifest_hash": {
      "type": "string"
    },
    "split_manifest_hash": {
      "type": "string"
    },
    "acquisition_policy_hash": {
      "type": "string"
    },
    "maximum_spend_usd": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}$"
    },
    "authorized_currency": {
      "type": "string"
    },
    "authorized_at": {
      "type": "string"
    },
    "expires_at": {
      "type": "string"
    },
    "authorized_by": {
      "type": "string"
    },
    "confirmation_phrase": {
      "type": "string"
    },
    "purchase_authorized": {
      "type": "boolean"
    },
    "authorization_hash": {
      "type": "string"
    }
  }
}
