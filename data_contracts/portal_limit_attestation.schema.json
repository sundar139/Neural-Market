{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "neuralmarket:contract:portal_limit_attestation:1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["attestation_version", "portal_historical_limit_usd", "portal_limit_confirmed", "portal_limit_confirmed_at", "portal_limit_confirmed_by", "confirmation_method", "expires_at", "plan_hash", "attestation_hash"],
  "properties": {
    "attestation_version": {"type": "string"},
    "portal_historical_limit_usd": {"type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$"},
    "portal_limit_confirmed": {"type": "boolean"},
    "portal_limit_confirmed_at": {"type": "string"},
    "portal_limit_confirmed_by": {"type": "string"},
    "confirmation_method": {"const": "manual_portal_review"},
    "expires_at": {"type": "string"},
    "plan_hash": {"type": "string"},
    "attestation_hash": {"type": "string"}
  }
}
