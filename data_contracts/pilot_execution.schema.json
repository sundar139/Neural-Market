{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "neuralmarket:contract:pilot_execution:1.0",
  "type": "object",
  "required": [
    "request_id",
    "state",
    "attempt_count",
    "updated_at"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "planned",
        "preflight_validated",
        "authorized",
        "requesting",
        "downloaded",
        "raw_validated",
        "normalized",
        "quality_validated",
        "uncertain_billing",
        "billed_without_validated_artifact",
        "retry_eligible_after_manual_nonbilling_confirmation",
        "failed",
        "quarantined"
      ]
    },
    "attempt_count": {
      "type": "integer"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
