# Optional, non-secret NeuralMarket settings. Copy to `.env` (which stays ignored).
# Never place credentials, tokens, or private vendor paths in a tracked file.
NEURALMARKET_LOG_LEVEL=INFO
NEURALMARKET_DATA_ROOT=data
NEURALMARKET_ARTIFACT_ROOT=artifacts

# Required only for `neuralmarket data qualify`. Never commit a real key.
DATABENTO_API_KEY=replace_with_your_historical_api_key
